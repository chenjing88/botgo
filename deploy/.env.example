# ============================================
# Botbotgogo 环境配置
# ============================================

# 阿里云百炼 API Key（必须）
# 申请地址: https://bailian.console.aliyun.com/
# 新用户有 100 万输入 + 100 万输出免费额度
DASHSCOPE_API_KEY=sk-your-api-key-here

# 心跳间隔（秒），默认 180（3分钟）
HEARTBEAT_INTERVAL=180

# 新闻源区域: cn=国内源, intl=国际源（BBC/Reuters/HackerNews/DevTo）
NEWS_REGION=cn

# 是否显示详细日志（true/false）
VERBOSE=false

# Firebase 配置（在 firebase-applet-config.json 中）
# 如果使用 Vercel 部署，在 Vercel 环境变量中配置
